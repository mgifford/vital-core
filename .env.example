# Copy to .env (gitignored) for local use. In CI these are provided as
# repository secrets, NOT read from this file.

# Hugging Face write token with access to the target Space.
# Used by .github/workflows/deploy-huggingface.yml (as the HF_TOKEN secret).
HF_TOKEN=

# Optional: local or on-prem LLM server for AI summaries in ai-findings
# output. Any OpenAI-compatible chat-completions server works (llama.cpp's
# llama-server, Ollama's /v1/ endpoint, LM Studio, etc.). Default here points
# at an on-prem llama.cpp box with more RAM than a laptop — override or leave
# unset to fall back to http://localhost:11434.
VITAL_OLLAMA_URL=http://192.168.50.171:11434
# Optional: pin a specific model. Leave unset to use the first available model.
VITAL_OLLAMA_MODEL=
