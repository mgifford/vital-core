re likely than men to have chronic symptoms of pain, aching, or stiffness in or around a joint for >3 months. This pattern was observed regardless of race/ethnicity. Among non-Hispanic black adults, 29.0% of women had chronic joint pain compared with 23.2% of men. Among non-Hispanic white adults, 30.2% of women had chronic joint pain compared with 28.4% of men. Among Hispanic adults, 24.1% of women had chronic joint pain compared with 19.0% of men. Hispanic men and women also were less likely than non-Hispanic black and non-Hispanic white men and women to have chronic joint pain.","hasAlt":true,"isDecorative":false,"isMissingAlt":false,"ariaHidden":false,"rolePresentation":false,"renderedWidth":555,"renderedHeight":380,"naturalWidth":555,"naturalHeight":380,"loading":null,"decoding":"async","altVerdict":"TOO_LONG","altReason":"alt text is 662 characters — consider a caption or description","bytes":30183},{"src":"https://www.cdc.gov/TemplatePackage/5.0/img/logo/cdc-logo-tag-right.svg","alt":"Centers for Disease Control and Prevention","hasAlt":true,"isDecorative":false,"isMissingAlt":false,"ariaHidden":false,"rolePresentation":false,"renderedWidth":283,"renderedHeight":66,"naturalWidth":827,"naturalHeight":193,"loading":null,"decoding":null,"altVerdict":"GOOD","altReason":"present, no red flags","bytes":4780},{"src":"https://www.cdc.gov/TemplatePackage/contrib/libs/cdc/c2r/crlogo.svg","alt":"Content Credentials logo","hasAlt":true,"isDecorative":false,"isMissingAlt":false,"ariaHidden":false,"rolePresentation":false,"renderedWidth":25,"renderedHeight":150,"naturalWidth":150,"naturalHeight":150,"loading":null,"decoding":null,"altVerdict":"GOOD","altReason":"present, no red flags","bytes":1490}]},"standards":{"engine":"standards","checks":[{"id":"schema-gov","label":"schema.org GovernmentOrganization markup","pass":false,"detail":""},{"id":"canonical","label":"Canonical URL declared","pass":true,"detail":""},{"id":"hreflang","label":"hreflang alternates declared","pass"