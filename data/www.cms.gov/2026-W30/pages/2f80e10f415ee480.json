tVerdict":"GOOD","altReason":"present, no red flags","bytes":27803},{"src":"https://www.cms.gov/sites/default/files/styles/desktop_width/public/2026-04/figure-1-measurement-cycle_0.jpg?itok=xZfFfCsJ","alt":"Graphic of CMS EPCS Program measurement cycle","hasAlt":true,"isDecorative":false,"isMissingAlt":false,"ariaHidden":false,"rolePresentation":false,"renderedWidth":904,"renderedHeight":351,"naturalWidth":null,"naturalHeight":null,"loading":"lazy","decoding":null,"altVerdict":"SUSPICIOUS","altReason":"redundant phrasing: \"graphic of…\"","bytes":null},{"src":"https://www.cms.gov/sites/default/files/styles/desktop_width/public/2024-06/important_info_about_the_cms_epcs_program.jpg?itok=12s9Tbmn","alt":"Important information about the CMS EPCS Program  ⦁\tPrescribers do not register for the CMS EPCS Program or send data directly to CMS. The CMS EPCS Program automatically calculates prescriber compliance using Medicare Part D claims.  ⦁\tPractitioners issuing electronic prescriptions for controlled substances must use a software application that meets all Drug Enforcement Administration (DEA) requirements. No additional e-prescribing software system is needed to meet the requirement for the CMS EPCS Program.  ⦁\tPrescribers experiencing technical issues when electronically prescribing controlled substances should contact their software vendor. Examples include log-in issues related to username or password, multi-factor authentication codes, or prescription transmission errors.  ⦁\tThere is no requirement for Part D sponsors or pharmacists to verify that a prescriber has a waiver (or is otherwise exempt) from the CMS EPCS requirement before covering or dispensing a Part D drug.   ⦁\tThe CMS EPCS requirement does not affect the ability of the Part D plan to cover or the pharmacists' ability to continue to dispense covered Part D drugs from otherwise valid written, oral, or fax prescriptions that are consistent with laws and regulations.  ⦁\tPrescribers of controlled substances can access the CMS EPCS Prescriber Portal to view their compliance rate and exception or waiver status in the fall following the measurement year. You must have a HCQIS Access Roles and Profile (HARP) account to access the portal.","hasAlt":true,"isDecorative":false,"isMissingAlt":false,"ariaHidden":false,"rolePresentation":false,"renderedWidth":904,"renderedHeight":494,"naturalWidth":null,"naturalHeight":null,"loading":"lazy","decoding":null,"altVerdict":"TOO_LONG","altReason":"alt text is 1520 characters — consider a caption or description","bytes":null},{"src":"https://www.cms.gov/sites/default/files/styles/desktop_width/public/2024-06/epcs_compliance_rate.jpg?itok=kvrn8QUU","alt":"EPCS Compliance Rate (%) equals the number of electronically prescribed Part D schedule 2 through 5 controlled substance prescription claims from the prescriber, after exceptions, divided by the number of all Part D schedule 2 through 5 controlled substance prescription claims from the prescriber, after exceptions, multiplied by 100 percent. ","hasAlt":true,"isDecorative":false,"isMissingAlt":false,"ariaHidden":false,"rolePresentation":false,"renderedWidth":904,"renderedHeight":129,"naturalWidth":null,"naturalHeight":null,"loading":"lazy","decoding":null,"altVerdict":"TOO_LONG","altReason":"alt text is 343 characters — consider a caption or description","bytes":null},{"src":"https://www.cms.gov/themes/custom/cms_evo/logo.svg","alt":"CMS.gov","hasAlt":true,"isDecorative":false,"isMissingAlt":false,"ariaHidden":false,"rolePresentation":false,"renderedWidth":167,"renderedHeight":40,"naturalWidth":300,"naturalHeight":72,"loading":null,"decoding":null,"altVerdict":"GOOD","altReason":"present, no red flags","bytes":2083},{"src":"https://www.cms.gov/themes/custom/cms_evo/images/hhslogo.png","alt":"HHS Logo","hasAlt":true,"isDecorative":false,"isMissingAlt":false,"ariaHidden":false,"rolePresentation":false,"renderedWidth":52,"renderedHeight":52,"naturalWidth":65,"naturalHeight":65,"loading":null,"decoding":null,"altVerdict":"GOOD","altReason":"present, no red flags","bytes":2762}]}}